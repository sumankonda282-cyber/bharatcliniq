# BharatCliniq Backend — Environment Variables
# Fill in real values and save as .env

# Database
DATABASE_URL=postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres

# Auth
SECRET_KEY=your-secret-key-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# App
APP_NAME=BharatCliniq
APP_VERSION=2.0.0
DEBUG=false

# OTP (false in production)
OTP_MOCK=false

# Brevo Email
BREVO_API_KEY=xkeysib-xxxx
BREVO_SENDER_EMAIL=noreply@bharathhealthsystems.com
BREVO_SENDER_NAME=BharatCliniq

# 2Factor.in SMS
TWO_FACTOR_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Razorpay
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Daily.co Telehealth
DAILY_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DAILY_DOMAIN=bharatcliniq

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=000000000000000
CLOUDINARY_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Plan Limits
FREE_PLAN_MAX_DOCTORS=2
FREE_PLAN_MAX_BRANCHES=1
UPLOAD_DIR=uploads
