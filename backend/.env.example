# ──────────────────────────────────────────────────────────────────
# BharatCliniq v2 — Environment Variables
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────────────────────────

# ── Database (Supabase PostgreSQL) ────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres.XXXX:PASSWORD@aws-0-ap-south-1.pooler.supabase.com:5432/postgres

# ── Security ─────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── App ───────────────────────────────────────────────────────────
DEBUG=true
APP_VERSION=2.0.0

# ── CORS (comma-separated list of allowed origins) ───────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175,https://bharatcliniq.com,https://provider.bharatcliniq.com,https://my.bharatcliniq.com

# ── OTP / SMS (Fast2SMS) ─────────────────────────────────────────
# Set OTP_MOCK=true during development to skip real SMS
OTP_MOCK=true
FAST2SMS_API_KEY=

# ── File Uploads ─────────────────────────────────────────────────
UPLOAD_DIR=uploads

# ── Subscription Plan Limits ──────────────────────────────────────
FREE_PLAN_MAX_DOCTORS=2
FREE_PLAN_MAX_BRANCHES=1

# ── Cloudinary (optional, for cloud image storage) ───────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
